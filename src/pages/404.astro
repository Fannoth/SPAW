---
import Layout from '../layouts/Layout.astro'
---

<Layout title="404 — Nie znaleziono | StalLoft">
  <section class="min-h-screen flex items-center justify-center bg-dark">
    <div class="text-center px-4">
      <h1 class="text-7xl sm:text-9xl font-bold text-primary mb-4">404</h1>
      <p class="text-xl sm:text-2xl text-cream/80 mb-8">Strona nie została znaleziona</p>
      <a
        href="/"
        class="inline-block px-8 py-3 bg-primary text-cream font-semibold uppercase tracking-wider text-sm rounded hover:bg-primary/90 transition-colors"
      >
        Wróć na stronę główną
      </a>
    </div>
  </section>
</Layout>
