---
import { reader } from '../../utils/keystatic'

const allTestimonials = await reader.collections.testimonials.all()
const cmsItems = allTestimonials
  .sort((a, b) => (a.entry.order ?? 0) - (b.entry.order ?? 0))
  .map((t) => ({
    name: t.entry.name,
    role: t.entry.role,
    content: t.entry.content,
    rating: t.entry.rating ?? 5,
  }))

const fallbackItems = [
  { name: 'Jan Kowalski', role: 'Właściciel domu', content: 'Stół industrialny jest dokładnie taki jak sobie wyobrażałem. Świetna jakość!', rating: 5 },
  { name: 'Anna Nowak', role: 'Architekt wnętrz', content: 'Współpracuję z StalLoft przy wielu projektach. Zawsze terminowo i solidnie.', rating: 5 },
  { name: 'Piotr Wiśniewski', role: 'Właściciel firmy', content: 'Profesjonalne podejście od projektu po montaż. Cena adekwatna do jakości.', rating: 5 },
]

const testimonials = cmsItems.length > 0 ? cmsItems : fallbackItems
---

<section id="opinie" class="py-20 bg-light">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold uppercase tracking-wider mb-4">Opinie klientów</h2>
      <p class="text-metal max-w-2xl mx-auto">Co mówią o nas nasi klienci</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
      {testimonials.map((t) => (
        <div class="animate-on-scroll bg-cream border border-metal/20 rounded-lg p-6">
          <div class="flex gap-1 mb-4">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg
                class={`w-5 h-5 ${i < t.rating ? 'text-primary' : 'text-metal/30'}`}
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <blockquote class="text-dark/80 leading-relaxed mb-4">
            "{t.content}"
          </blockquote>

          <div class="border-t border-metal/20 pt-4">
            <p class="font-bold text-sm">{t.name}</p>
            <p class="text-metal text-xs">{t.role}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
