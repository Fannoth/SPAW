---
import { reader } from '../../utils/keystatic'

const allSteps = await reader.collections.processSteps.all()
const cmsSteps = allSteps
  .sort((a, b) => (a.entry.stepNumber ?? 0) - (b.entry.stepNumber ?? 0))
  .map((s) => ({
    title: s.entry.title,
    description: s.entry.description,
    stepNumber: s.entry.stepNumber ?? 0,
    icon: s.entry.icon,
  }))

const allCerts = await reader.collections.certificates.all()
const cmsCerts = allCerts
  .sort((a, b) => (a.entry.order ?? 0) - (b.entry.order ?? 0))
  .map((c) => ({
    title: c.entry.title,
    description: c.entry.description,
    image: c.entry.image || '',
  }))

const fallbackSteps = [
  { title: 'Kontakt', description: 'Skontaktuj się z nami. Opisz swój pomysł.', stepNumber: 1, icon: 'phone' },
  { title: 'Wycena', description: 'Przygotujemy bezpłatną wycenę.', stepNumber: 2, icon: 'calculator' },
  { title: 'Realizacja', description: 'Wykonujemy projekt w naszym warsztacie.', stepNumber: 3, icon: 'tools' },
  { title: 'Odbiór', description: 'Dostarczamy i montujemy na miejscu.', stepNumber: 4, icon: 'check' },
]

const fallbackCerts = [
  { title: 'Uprawnienia spawalnicze', description: 'Certyfikowane uprawnienia MIG/MAG i TIG', image: '' },
  { title: 'Certyfikat jakości', description: 'System zarządzania jakością spawania', image: '' },
  { title: 'Ubezpieczenie OC', description: 'Pełne ubezpieczenie OC działalności', image: '' },
]

const steps = cmsSteps.length > 0 ? cmsSteps : fallbackSteps
const certs = cmsCerts.length > 0 ? cmsCerts : fallbackCerts

const iconPaths: Record<string, string> = {
  phone: 'M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z',
  calculator: 'M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V13.5zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V18zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V13.5zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V18zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V18zm2.498-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zM8.25 6h7.5v2.25h-7.5V6zM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.65 4.5 4.757V19.5a2.25 2.25 0 002.25 2.25h10.5a2.25 2.25 0 002.25-2.25V4.757c0-1.108-.806-2.057-1.907-2.185A48.507 48.507 0 0012 2.25z',
  tools: 'M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085',
  check: 'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
}
---

<section id="proces" class="py-20 bg-light">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold uppercase tracking-wider mb-4">Jak pracujemy</h2>
      <p class="text-metal max-w-2xl mx-auto">Od pomysłu do realizacji w 4 krokach</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-20 stagger-children">
      {steps.map((step, i) => (
        <div class="animate-on-scroll text-center relative">
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute top-8 left-[calc(50%+2rem)] w-[calc(100%-4rem)] h-px bg-metal/30"></div>
          )}
          <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-primary/10 border-2 border-primary flex items-center justify-center relative">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[step.icon] || iconPaths.check} />
            </svg>
          </div>
          <div class="text-xs font-bold text-primary uppercase tracking-widest mb-2">Krok {step.stepNumber}</div>
          <h3 class="font-bold text-lg mb-2">{step.title}</h3>
          <p class="text-metal text-sm">{step.description}</p>
        </div>
      ))}
    </div>

    <div class="text-center mb-12">
      <h3 class="text-2xl font-bold uppercase tracking-wider mb-4">Certyfikaty i uprawnienia</h3>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      {certs.map((cert) => (
        <div class="animate-on-scroll bg-cream border border-metal/20 rounded-lg p-6 text-center">
          <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-primary/10 flex items-center justify-center">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
            </svg>
          </div>
          <h4 class="font-bold mb-2">{cert.title}</h4>
          <p class="text-metal text-sm">{cert.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
